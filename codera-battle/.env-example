# ── Datenbank (PostgreSQL) ───────────────────────────────────────────
# Jede/r Lernende nutzt die eigene lokale PostgreSQL-Instanz (M164).
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=codera
DB_SSLMODE=disable

# ── Logging (Code-Kleriker*in) ───────────────────────────────────────
# Log-Level: debug | info | warn | error
LOG_LEVEL=info
# Logfile-Pfad. Der Ordner ./logs/ ist via .gitignore ausgeschlossen.
LOG_PATH=./logs/battle.log
